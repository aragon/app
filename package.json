    "@walletconnect/utils": "^2.23.6",
    "classnames": "^2.5.1",
    "deepmerge-ts": "^7.1.5",
    "framer-motion": "^12.34.2",
    "import-in-the-middle": "^2.0.6",
    "isomorphic-dompurify": "^2.36.0",
    "jsdom": "^26.1.0",
    "luxon": "^3.7.2",
    "next": "^16.1.6",
    "nextjs-toploader": "^3.9.17",
