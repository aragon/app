{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "paths": {
            "@e2e/*": [
                "./*"
            ]
        }
    },
    "include": [
        "./**/*.ts"
    ]
}
