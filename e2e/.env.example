# Copy to e2e/.env. Values come from 1Password: kv_app_infra → E2E_FE_MM_WALLET
# (same field labels as in the vault).
#
# E2E_FE_MM_WALLET_SECRET_RECOVERY_PHRASE="word1 word2 ... word12"
# E2E_FE_MM_WALLET_PASSWORD="your_password"

# Optional: target URL for BV (defaults to localhost in playwright.bv.config if unset).
# E2E_BASE_URL=https://stg.app.aragon.org

# One-time: build Synpress MetaMask profile cache (required before e2e:bv). Also copies the
# CLI output to `.cache-synpress/wallet-setup/` so Playwright matches the stable cache key.
#   pnpm e2e:bv:wallet-cache

# Optional — treasuryWithdrawal.spec.ts without full suite:
# BV_E2E_PROPOSAL_TITLE=...
# BV_E2E_PROPOSAL_URL=https://...
